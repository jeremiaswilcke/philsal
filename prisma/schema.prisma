generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model MembershipApplication {
  id              Int      @id @default(autoincrement())
  name            String
  telefon         String
  strasse         String
  hausnummer      String
  plz             String
  ort             String
  land            String   @default("Österreich")
  email           String
  datenschutz     Boolean
  telegramWilling Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model ContactInquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  kategorie String
  eventId   String?
  nachricht String
  createdAt DateTime @default(now())
}

model EventRegistration {
  id        Int      @id @default(autoincrement())
  eventSlug String
  name      String
  email     String
  telefon   String?
  personen  Int      @default(1)
  anmerkung String?
  createdAt DateTime @default(now())

  @@index([eventSlug])
}
